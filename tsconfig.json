{
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"],
    "compilerOptions": {
        "baseUrl": "./",
        "moduleResolution": "bundler",
        "allowJs": true,
        "paths": {
            "@messages/*": ["messages/*.json"],
            "@assets/*": ["src/assets/*"],
            "@components/*": ["src/components/*"],
            "@layouts/*": ["src/layouts/*"],
            "@pages/*": ["src/pages/*"],
            "@paraglide/*": ["src/paraglide/*"],
            "@styles/*": ["src/styles/*"],
            "@utils/*": ["src/utils/*"]
        },
        "strictNullChecks": true
    }
}
