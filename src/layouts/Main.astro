---
import Head from "@components/Head.astro";
import Footer from "@components/Footer.astro";
import { Image } from "astro:assets";
import Nav from "@components/Nav.astro";
import "@styles/global.css";
import * as m from "@paraglide/messages.js";
import bosomOfFather from "@assets/images/bosom-of-father.webp";

interface Props {
    title?: string;
    description?: string;
}

const { title = m.LAYOUT_SITE_TITLE(), description = "" } = Astro.props;
---

<!doctype html>
<html lang="en" class="min-h-full">
    <head>
        <Head title={title} description={description} />
    </head>
    <body class="relative min-h-screen w-full">
        <Image
            src={bosomOfFather}
            alt=""
            class="fixed inset-0 h-full w-full object-cover object-center -z-10"
            aria-hidden="true"
            loading="eager"
            fetchpriority="high"
        />
        <main class="min-h-screen">
            <Nav />
            <slot />
        </main>
        <Footer />
    </body>
</html>
