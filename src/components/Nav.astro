---
import * as m from "@paraglide/messages.js";

const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || (path !== "/" && currentPath.startsWith(path));

const navLinks = [
    { href: "/", label: m.NAV_HOME() },
    { href: "/contact", label: m.NAV_CONTACT() },
    { href: "/schedule", label: m.NAV_SCHEDULE() },
    { href: "/donations", label: m.NAV_DONATIONS() },
];

const aboutLinks = [
    { href: "/our-church", label: m.NAV_OUR_CHURCH() },
    { href: "/clergy", label: m.NAV_CLERGY() },
    { href: "/board-of-deacons", label: m.NAV_BOARD_OF_DEACONS() },
];

const resourceLinks = [
    { href: "/beechwood", label: m.NAV_BEECHWOOD() },
    { href: "/booklets", label: m.NAV_BOOKLETS() },
    { href: "/cottage", label: m.NAV_COTTAGE() },
    { href: "/deacons-schedule", label: m.NAV_DEACONS_SCHEDULE() },
    { href: "/library", label: m.NAV_LIBRARY() },
    { href: "/lighthouse", label: m.NAV_LIGHTHOUSE() },
    { href: "/live", label: m.NAV_LIVE() },
    { href: "/new-comers", label: m.NAV_NEW_COMERS() },
    { href: "/posts", label: m.NAV_POSTS() },
    { href: "/relics", label: m.NAV_RELICS() },
    { href: "/sacraments", label: m.NAV_SACRAMENTS() },
    { href: "/sermons", label: m.NAV_SERMONS() },
    { href: "/servants", label: m.NAV_SERVANTS() },
];

const dropdowns = [
    { id: "about", label: m.NAV_ABOUT(), links: aboutLinks },
    { id: "resources", label: m.NAV_RESOURCES(), links: resourceLinks },
];

const linkClasses = (href: string) =>
    isActive(href) ? "font-cormorant italic text-lg lg:text-xl text-gold underline decoration-gold underline-offset-4" : "font-cormorant italic text-lg lg:text-xl text-gold hover:underline hover:decoration-gold hover:underline-offset-4";

const mobileLinkClasses = (href: string) =>
    isActive(href)
        ? "font-cormorant italic text-lg lg:text-xl text-gold underline decoration-gold underline-offset-4"
        : "font-cormorant italic text-lg lg:text-xl text-gold hover:underline hover:decoration-gold hover:underline-offset-4";

const dropdownHasActive = (links: { href: string }[]) => links.some((l) => isActive(l.href));
---

<nav class="sticky top-0 z-60 bg-platinum shadow-sm">
    <div class="mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-14 lg:h-20 items-center">
            <!-- Mobile/Tablet logo -->
            <a href="/" class="lg:hidden">
                <img src="/icons/sgsa-logo-gold-shadow.svg" alt="SGSA Logo" class="h-14 w-auto" />
            </a>
            <!-- Desktop: logo left, nav links centered -->
            <div class="hidden lg:grid grid-cols-[auto_1fr_auto] items-center w-full">
                <a href="/" class="flex-shrink-0">
                    <img src="/icons/sgsa-logo-gold-shadow.svg" alt="SGSA Logo" class="h-20 w-auto" />
                </a>
                <div class="flex items-center justify-center gap-4 xl:gap-10">
                    {
                        navLinks.slice(0, 1).map(({ href, label }) => (
                            <a href={href} class:list={["px-3 py-2 font-medium transition-colors", linkClasses(href)]}>
                                {label}
                            </a>
                        ))
                    }

                    {
                        dropdowns.slice(0, 1).map(({ id, label, links }) => (
                            <div class="relative group" data-desktop-dropdown={id}>
                                <button
                                    type="button"
                                    class:list={[
                                        "flex items-center px-2 xl:px-5 py-2 font-cormorant italic text-lg lg:text-xl font-medium h-14 lg:h-20 transition-colors",
                                        links.some((l) => isActive(l.href))
                                            ? "text-gold underline decoration-gold underline-offset-4"
                                            : "text-gold hover:underline hover:decoration-gold hover:underline-offset-4",
                                    ]}
                                    aria-expanded="false"
                                    aria-haspopup="true"
                                    id={`${id}-menu-button`}
                                >
                                    {label}
                                    <svg
                                        class="ml-1 h-4 w-4"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                        aria-hidden="true"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                </button>
                                <div
                                    class="absolute left-0 top-full w-56 pt-2 hidden group-hover:block dropdown-panel"
                                    role="menu"
                                    aria-orientation="vertical"
                                    aria-labelledby={`${id}-menu-button`}
                                >
                                    <div class="rounded-md bg-platinum shadow-lg ring-1 ring-white/20 py-1">
                                        {links.map(({ href, label: linkLabel }) => (
                                            <a
                                                href={href}
                                                class:list={[
                                                    "block px-4 py-2 text-sm transition-colors",
                                                    linkClasses(href),
                                                ]}
                                                role="menuitem"
                                            >
                                                {linkLabel}
                                            </a>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))
                    }

                    {
                        navLinks.slice(1).map(({ href, label }) => (
                            <a href={href} class:list={["px-3 py-2 font-medium transition-colors", linkClasses(href)]}>
                                {label}
                            </a>
                        ))
                    }

                    {
                        dropdowns.slice(1).map(({ id, label, links }) => (
                            <div class="relative group" data-desktop-dropdown={id}>
                                <button
                                    type="button"
                                    class:list={[
                                        "flex items-center px-2 xl:px-5 py-2 font-cormorant italic text-lg lg:text-xl font-medium h-14 lg:h-20 transition-colors",
                                        links.some((l) => isActive(l.href))
                                            ? "text-gold underline decoration-gold underline-offset-4"
                                            : "text-gold hover:underline hover:decoration-gold hover:underline-offset-4",
                                    ]}
                                    aria-expanded="false"
                                    aria-haspopup="true"
                                    id={`${id}-menu-button`}
                                >
                                    {label}
                                    <svg
                                        class="ml-1 h-4 w-4"
                                        fill="currentColor"
                                        viewBox="0 0 20 20"
                                        aria-hidden="true"
                                    >
                                        <path
                                            fill-rule="evenodd"
                                            d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                                            clip-rule="evenodd"
                                        />
                                    </svg>
                                </button>
                                <div
                                    class="absolute left-0 top-full w-56 pt-2 hidden group-hover:block dropdown-panel"
                                    role="menu"
                                    aria-orientation="vertical"
                                    aria-labelledby={`${id}-menu-button`}
                                >
                                    <div class="rounded-md bg-platinum shadow-lg ring-1 ring-white/20 py-1">
                                        {links.map(({ href, label: linkLabel }) => (
                                            <a
                                                href={href}
                                                class:list={[
                                                    "block px-4 py-2 text-sm transition-colors",
                                                    linkClasses(href),
                                                ]}
                                                role="menuitem"
                                            >
                                                {linkLabel}
                                            </a>
                                        ))}
                                    </div>
                                </div>
                            </div>
                        ))
                    }
                </div>
                <!-- Spacer to balance logo width for centered nav -->
                <div></div>
            </div>

            <!-- Hamburger button (mobile/tablet) -->
            <button
                type="button"
                class="lg:hidden inline-flex items-center justify-center p-2 rounded-md text-gold hover:bg-white/10"
                aria-controls="mobile-menu"
                aria-expanded="false"
                id="mobile-menu-button"
            >
                <svg
                    class="h-7 w-7"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="2"
                    stroke="currentColor"
                    aria-hidden="true"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"
                    >
                    </path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile menu placeholder (content moved outside nav) -->
</nav>

<div
    id="mobile-menu"
    class="lg:hidden fixed left-0 right-0 h-[calc(100vh-3.5rem)] z-50 overflow-y-auto transition-transform duration-300 ease-in-out"
    style="top: 3.5rem; transform: translateY(-100vh);"
>
    <div class="px-2 pt-2 pb-3 space-y-1 min-h-full bg-platinum">
        {
            navLinks.slice(0, 1).map(({ href, label }) => (
                <a
                    href={href}
                    class:list={[
                        "block px-3 py-2 rounded-md text-xl font-medium transition-colors",
                        mobileLinkClasses(href),
                    ]}
                >
                    {label}
                </a>
            ))
        }

        {
            dropdowns.slice(0, 1).map(({ id, label, links }) => {
                const expanded = dropdownHasActive(links);
                return (
                    <>
                        <button
                            type="button"
                            class="w-full flex justify-between items-center px-3 py-2 rounded-md font-cormorant italic text-xl font-medium text-gold hover:underline hover:decoration-gold hover:underline-offset-4 transition-colors"
                            data-accordion={id}
                        >
                            {label}
                            <svg
                                class:list={["h-6 w-6 transition-transform duration-200", expanded && "rotate-180"]}
                                data-chevron={id}
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                aria-hidden="true"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                                    clip-rule="evenodd"
                                />
                            </svg>
                        </button>
                        <div class:list={["pl-8 space-y-1", !expanded && "hidden"]} data-menu={id}>
                            {links.map(({ href, label: linkLabel }) => (
                                <a
                                    href={href}
                                    class:list={[
                                        "block px-3 py-2 rounded-md text-lg transition-colors",
                                        mobileLinkClasses(href),
                                    ]}
                                >
                                    {linkLabel}
                                </a>
                            ))}
                        </div>
                    </>
                );
            })
        }

        {
            navLinks.slice(1).map(({ href, label }) => (
                <a
                    href={href}
                    class:list={[
                        "block px-3 py-2 rounded-md text-xl font-medium transition-colors",
                        mobileLinkClasses(href),
                    ]}
                >
                    {label}
                </a>
            ))
        }

        {
            dropdowns.slice(1).map(({ id, label, links }) => {
                const expanded = dropdownHasActive(links);
                return (
                    <>
                        <button
                            type="button"
                            class="w-full flex justify-between items-center px-3 py-2 rounded-md font-cormorant italic text-xl font-medium text-gold hover:underline hover:decoration-gold hover:underline-offset-4 transition-colors"
                            data-accordion={id}
                        >
                            {label}
                            <svg
                                class:list={["h-6 w-6 transition-transform duration-200", expanded && "rotate-180"]}
                                data-chevron={id}
                                fill="currentColor"
                                viewBox="0 0 20 20"
                                aria-hidden="true"
                            >
                                <path
                                    fill-rule="evenodd"
                                    d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z"
                                    clip-rule="evenodd"
                                />
                            </svg>
                        </button>
                        <div class:list={["pl-8 space-y-1", !expanded && "hidden"]} data-menu={id}>
                            {links.map(({ href, label: linkLabel }) => (
                                <a
                                    href={href}
                                    class:list={[
                                        "block px-3 py-2 rounded-md text-lg transition-colors",
                                        mobileLinkClasses(href),
                                    ]}
                                >
                                    {linkLabel}
                                </a>
                            ))}
                        </div>
                    </>
                );
            })
        }
    </div>
</div>

<script>
    const menuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");

    menuButton?.addEventListener("click", () => {
        const isOpen = mobileMenu?.style.transform === "translateY(0px)";
        if (isOpen) {
            mobileMenu!.style.transform = "translateY(-100vh)";
            menuButton.setAttribute("aria-expanded", "false");
            document.body.classList.remove("overflow-hidden");
        } else {
            mobileMenu!.style.transform = "translateY(0px)";
            menuButton.setAttribute("aria-expanded", "true");
            document.body.classList.add("overflow-hidden");
        }
    });

    // Desktop dropdown click-to-toggle (for touch devices like iPad/tablet)
    document.querySelectorAll<HTMLDivElement>("[data-desktop-dropdown]").forEach((wrapper) => {
        const btn = wrapper.querySelector("button");
        btn?.addEventListener("click", () => {
            const isOpen = wrapper.classList.contains("dropdown-open");
            // Close all other open dropdowns
            document.querySelectorAll<HTMLDivElement>("[data-desktop-dropdown]").forEach((other) => {
                other.classList.remove("dropdown-open");
                other.querySelector("button")?.setAttribute("aria-expanded", "false");
            });
            if (!isOpen) {
                wrapper.classList.add("dropdown-open");
                btn.setAttribute("aria-expanded", "true");
            }
        });
    });

    // Close desktop dropdowns when clicking outside
    document.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (!target.closest("[data-desktop-dropdown]")) {
            document.querySelectorAll<HTMLDivElement>("[data-desktop-dropdown]").forEach((wrapper) => {
                wrapper.classList.remove("dropdown-open");
                wrapper.querySelector("button")?.setAttribute("aria-expanded", "false");
            });
        }
    });

    document.querySelectorAll<HTMLButtonElement>("[data-accordion]").forEach((btn) => {
        btn.addEventListener("click", () => {
            const id = btn.dataset.accordion;
            document.querySelector(`[data-menu="${id}"]`)?.classList.toggle("hidden");
            document.querySelector(`[data-chevron="${id}"]`)?.classList.toggle("rotate-180");
        });
    });
</script>

<style>
    .dropdown-open .dropdown-panel {
        display: block;
    }
</style>
