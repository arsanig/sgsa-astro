---
import Main from "@layouts/Main.astro";
import * as m from "@paraglide/messages.js";
import bosomOfFather from "@assets/images/bosom-of-father.webp";
---

<Main>
    <div
        class="bg-cover bg-center bg-no-repeat bg-fixed min-h-screen"
        style={`background-image: url('${bosomOfFather.src}');`}
    >
        <section class="flex flex-col items-center justify-center text-center px-4 py-14 md:py-18">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight">
                {m.HOME_BANNER_LINE1()}<br />
                <span class="italic">{m.HOME_BANNER_LINE2()}</span>
            </h1>
        </section>
        <section class="w-full bg-white/70 py-6 text-center">
            <blockquote class="max-w-xl mx-auto px-4">
                <p class="text-lg md:text-xl italic text-gold">{m.HOME_VERSE_TEXT()}</p>
                <cite class="block mt-2 text-sm text-gold/70 not-italic">[{m.HOME_VERSE_REF()}]</cite>
            </blockquote>
        </section>
        <section class="w-full max-w-5xl mx-auto px-4 py-12">
            <h2 class="text-center text-2xl md:text-3xl font-bold text-white mb-6">{m.HOME_UPCOMING_SERVICES()}</h2>
            <!-- Desktop: month view -->
            <iframe
                src="https://calendar.google.com/calendar/embed?ctz=America%2FNew_York&mode=MONTH&title=Service+Schedule&showCalendars=0&src=c_e1e56db6ebcb663b180c117d7ae5e62a5b356816fc36abd0ec44c7e55cd53f9a%40group.calendar.google.com&color=%23039BE5"
                class="hidden md:block w-full h-181 rounded-lg shadow-lg border-0"
                loading="lazy"
                title={m.SCHEDULE_PAGE_TITLE()}
            >
            </iframe>
            <!-- Mobile: schedule/agenda view -->
            <iframe
                src="https://calendar.google.com/calendar/embed?ctz=America%2FNew_York&mode=AGENDA&title=Service+Schedule&showPrint=0&showTabs=0&showCalendars=0&src=c_e1e56db6ebcb663b180c117d7ae5e62a5b356816fc36abd0ec44c7e55cd53f9a%40group.calendar.google.com&color=%23039BE5"
                class="md:hidden w-full h-150 rounded-lg shadow-lg border-0"
                loading="lazy"
                title={m.SCHEDULE_PAGE_TITLE()}
            >
            </iframe>
        </section>
    </div>
</Main>
