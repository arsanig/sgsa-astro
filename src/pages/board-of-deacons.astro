---
import Main from "@layouts/Main.astro";
import PageBanner from "@components/PageBanner.astro";
import * as m from "@paraglide/messages.js";
import sgsaOutside from "@assets/images/sgsa-outside.webp";
import bassem from "@assets/images/bassem-nashed.webp";
import manal from "@assets/images/manal-gorgui.webp";
import john from "@assets/images/john-youssef.webp";
import amir from "@assets/images/amir-elrashidy.webp";
---

<Main title={m.BOARD_OF_DEACONS_PAGE_TITLE()} description={""}>
    <div
        class="min-h-[80vh] bg-cover bg-center bg-no-repeat bg-fixed"
        style={`background-image: linear-gradient(color-mix(in srgb, var(--color-shadow) 92%, transparent), color-mix(in srgb, var(--color-shadow) 92%, transparent)), url('${sgsaOutside.src}');`}
    >
        <PageBanner title={m.BOARD_OF_DEACONS_PAGE_TITLE()} bg="bg-platinum" />

        <!-- Board's Purpose -->
        <section class="w-full py-12 md:py-16">
            <div class="max-w-4xl mx-auto px-6 text-center">
                <h2 class="text-2xl md:text-3xl font-playfair text-platinum mb-8">Purpose</h2>
                <p class="text-lg md:text-xl font-lora text-platinum/80 leading-relaxed text-justify">
                    The Board of Deacons at St. George and St. Anthony Coptic Orthodox Church is composed of one priest
                    along with four men or women from the congregation. The board is responsible for financial and
                    administrative decisions at our parish.
                </p>
            </div>
        </section>

        <!-- Members -->
        <section class="w-full py-12 md:py-16">
            <div class="max-w-4xl mx-auto px-6 text-center">
                <h2 class="text-2xl md:text-3xl font-playfair text-platinum mb-8">Members</h2>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-10">
                    <div class="flex flex-col items-center">
                        <img
                            src={bassem.src}
                            alt="Bassem Nashed"
                            class="w-48 h-48 md:w-64 md:h-64 rounded-2xl object-cover shadow-lg"
                        />
                        <h3 class="mt-5 text-lg md:text-xl font-lora text-platinum tracking-wide">Bassem Nashed</h3>
                        <p class="mt-1 text-xs md:text-sm font-lora text-platinum/60 uppercase tracking-widest">
                            Church Treasurer
                        </p>
                    </div>
                    <div class="flex flex-col items-center">
                        <img
                            src={manal.src}
                            alt="Manal Gorgui"
                            class="w-48 h-48 md:w-64 md:h-64 rounded-2xl object-cover shadow-lg"
                        />
                        <h3 class="mt-5 text-lg md:text-xl font-lora text-platinum tracking-wide">Manal Gorgui</h3>
                        <p class="mt-1 text-xs md:text-sm font-lora text-platinum/60 uppercase tracking-widest">
                            Female Representative
                        </p>
                    </div>
                    <div class="flex flex-col items-center">
                        <img
                            src={john.src}
                            alt="John Youssef"
                            class="w-48 h-48 md:w-64 md:h-64 rounded-2xl object-cover shadow-lg"
                        />
                        <h3 class="mt-5 text-lg md:text-xl font-lora text-platinum tracking-wide">John Youssef</h3>
                        <p class="mt-1 text-xs md:text-sm font-lora text-platinum/60 uppercase tracking-widest">
                            General Service Coordinator
                        </p>
                    </div>
                    <div class="flex flex-col items-center">
                        <img
                            src={amir.src}
                            alt="Amir El Rashidy"
                            class="w-48 h-48 md:w-64 md:h-64 rounded-2xl object-cover shadow-lg"
                        />
                        <h3 class="mt-5 text-lg md:text-xl font-lora text-platinum tracking-wide">Amir El Rashidy</h3>
                        <p class="mt-1 text-xs md:text-sm font-lora text-platinum/60 uppercase tracking-widest">
                            Secretary & Youth Representative
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact -->
        <section class="w-full py-12 md:py-16">
            <div class="max-w-4xl mx-auto px-6 text-center">
                <p class="text-base md:text-lg font-lora text-platinum/70 mb-8">
                    If you'd like to contact the board, <br />please email us at:
                </p>
                <a
                    href="mailto:board@orthodoxy.ca"
                    class="inline-flex items-center gap-2 bg-gold text-platinum px-6 py-3 rounded-lg text-sm md:text-lg hover:opacity-80 transition-opacity"
                >
                    <img
                        src="/icons/envelope.svg"
                        alt=""
                        class="w-4 h-4 md:w-5 md:h-5"
                        style="filter: brightness(0) invert(1) brightness(0.925);"
                    />
                    board@orthodoxy.ca
                </a>
            </div>
        </section>
    </div>
</Main>
