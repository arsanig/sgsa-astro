---
import Main from "@layouts/Main.astro";
import PageBanner from "@components/PageBanner.astro";
import * as m from "@paraglide/messages.js";
---

<Main title={m.NAV_SCHEDULE()} description={""}>
    <div class="min-h-screen bg-shadow">
        <PageBanner title={m.SCHEDULE_PAGE_TITLE()} />
        <div class="flex flex-col items-center justify-center px-4 mb-18">
            <!-- Desktop: month view -->
            <iframe
                src="https://calendar.google.com/calendar/embed?ctz=America%2FNew_York&mode=MONTH&title=Service+Schedule&showCalendars=0&src=c_e1e56db6ebcb663b180c117d7ae5e62a5b356816fc36abd0ec44c7e55cd53f9a%40group.calendar.google.com&color=%23039BE5"
                class="hidden md:block w-full md:w-[90%] lg:w-[80%] xl:w-[70%] mx-auto h-150 lg:h-225 xl:h-250 rounded-lg shadow-lg border-0"
                loading="lazy"
                title={m.SCHEDULE_PAGE_TITLE()}
            >
            </iframe>
            <!-- Mobile: schedule/agenda view -->
            <iframe
                src="https://calendar.google.com/calendar/embed?ctz=America%2FNew_York&mode=AGENDA&title=Service+Schedule&showPrint=0&showTabs=0&showCalendars=0&src=c_e1e56db6ebcb663b180c117d7ae5e62a5b356816fc36abd0ec44c7e55cd53f9a%40group.calendar.google.com&color=%23039BE5"
                class="md:hidden w-full h-125 rounded-lg shadow-lg border-0"
                loading="lazy"
                title={m.SCHEDULE_PAGE_TITLE()}
            >
            </iframe>
        </div>
    </div>
</Main>
